ENV=prod

ALLOW_TRADING=true

# =============================================================================
# Cointegration Scanner Configuration
# =============================================================================

# Workers Amount
WORKERS_AMOUNT=2

# =============================================================================
# Exchange Configuration
# =============================================================================
EXCHANGE_NAME="binance"
EXCHANGE_API_KEY=""
EXCHANGE_API_SECRET=""
EXCHANGE_TESTNET=false
EXCHANGE_DEFAULT_LEVERAGE=10
EXCHANGE_MARGIN_TYPE="cross"  # "cross" or "isolated"
EXCHANGE_QUOTE_CURRENCY="USDT"

# =============================================================================
# Screener Configuration
# =============================================================================
TIMEFRAME=15m
SCAN_CRON_EXPRESSION="*/15 * * * *"  # Every 15 minutes
LOOKBACK_WINDOW_DAYS=3        # 3 days (for 15m timeframe)
MIN_CORRELATION=0.8      # Базовый фильтр. Для поиска новых связок
CORRELATION_WATCH_THRESHOLD=0.77  # Порог корреляции для удаления из списка наблюдаемых.
PRIMARY_PAIR="ETH/USDT:USDT"
CONSISTENT_PAIRS="LINK/USDT:USDT, AAVE/USDT:USDT, ONDO/USDT:USDT, RENDER/USDT:USDT, MANA/USDT:USDT, ETHFI/USDT:USDT"
# Z-Score
Z_ENTRY_THRESHOLD=2.1    # Вход
Z_TP_THRESHOLD=0.25     # Выход
Z_SL_THRESHOLD=4    # Стоп-лосс
Z_SL_EXTREME_OFFSET=0.5 # Стоп-лосс для extreme кейса от z-entry
Z_EXTREME_LEVEL=6       # Extreme значение. Если выше - пара не попадет в EntryObserver. Для этого значения будет применятся
ADAPTIVE_PERCENTILE=95 # Адаптивный перцентиль для динамического Z-Score
DYNAMIC_THRESHOLD_WINDOW_BARS=440 # Динамический Z-Score окно (440 баров = 4 дня для 15минутных баров)
Z_SCORE_PROGRESS_EXIT_THRESHOLD=0.3 # 30% будет использоваться в связке с друкгими фильтрами для закрытия позиции если прогресс < порога за n время
# Asymmetric EMA for threshold smoothing
# alpha_up = slow increase (don't miss opportunities when vol spikes)
# alpha_down = faster decrease (capture more entries when vol drops)
THRESHOLD_EMA_ALPHA_UP=0.01  # Slow rise: 1% new, 99% old
THRESHOLD_EMA_ALPHA_DOWN=0.05  # Faster fall: 5% new, 95% old
# Beta
MAX_BETA = 2.0
MIN_BETA = 0.5
ENABLE_BETA_DRIFT_GUARD=true
BETA_DRIFT_SHORT_DAYS=3
BETA_DRIFT_LONG_DAYS=9
BETA_DRIFT_MAX_RELATIVE=0.35
ENABLE_STABILITY_FILTER=true
STABILITY_WINDOWS_DAYS=3,6,9
STABILITY_MIN_PASS_WINDOWS=2
# Hurst
HURST_THRESHOLD=0.45
HURST_WATCH_THRESHOLD=0.46  # Tolerance для watches (0.45 + 0.01 = 0.41 для удержания)
HURST_TRENDING_FOR_EXIT=0.46  # Tolerance для удержание позиций (0.45 + 0.02 = 0.47 для удержания)
HURST_TRENDING_CONFIRM_SCANS=2 # Подтверждение сканированиями
HURST_LOOKBACK_CANDLES=300
# Half-Life
HALFLIFE_MAX_BARS=48.0  # 0.5 * MAX_POSITION_BARS 4h
HALFLIFE_LOOKBACK_CANDLES=300  # 300 свечей для расчета Half-Life
HALFLIFE_EXIT_CONFIRM_SCANS=2  # Кол-во сканов подтверждения деградации Half-Life для выхода
# ADF settings
ADF_PVALUE_THRESHOLD=0.15  # Максимальный p-value для стационарности (0.08 - база, 0.10 - пропустит больше шума, 0.15 - для максимального ослабления)
ADF_LOOKBACK_CANDLES=300  # 300 свечей для расчета ADF
ADF_EXIT_CONFIRM_SCANS=2  # Кол-во сканов подтверждения ADF-деградации для выхода
# Volatility filter
VOLATILITY_WINDOW=24  # 6 hours (24 x 15min candles)
VOLATILITY_THRESHOLD=0.018
VOLATILITY_CRASH_WINDOW=16  # 4 hours (16 x 15min candles)
VOLATILITY_CRASH_THRESHOLD=0.05
# Funding filter
# Block entry if net funding cost exceeds this threshold per 8h
# -0.0005 = -0.05% (5x standard rate of 0.01%)
MAX_FUNDING_COST_THRESHOLD=-0.0010

# =============================================================================
# Trading Configuration
# =============================================================================
POSITION_SIZE_USDT=1000     # Position size in USDT
MAX_OPEN_SPREADS=6  # Max concurrent open spread
# Position state settings
COOLDOWN_BARS=16  # Cooldown after SL/CORRELATION_DROP (16 bars = 4h for 15m)
MAX_POSITION_BARS=192  # Max position duration before timeout (96b=24h for 15m)
# Trailing Entry (Smart Entry)
TRAILING_ENTRY_PULLBACK=0.07          # Z-score pullback for reversal confirmation (0.25 normal, 0.15 just for testing all flow)
TRAILING_ENTRY_PULLBACK_EXTREME=0.6   # Z-score pullback for reversal confirmation after extreme pamp
TRAILING_ENTRY_TIMEOUT_MINUTES=120     # Max watch duration before cancellation
FALSE_ALARM_HYSTERESIS=0.45           # Buffer for deviations from Z-score pullback
# Dynamic Position Sizing based on Half-Life
# Size = BaseSize × (TargetHalfLife / CurrentHalfLife)
# Fast reversion (low HL) → larger size, slow reversion (high HL) → smaller size
TARGET_HALFLIFE_BARS=16.0  # Target HL = 12 bars (3h for 15m) as baseline
MIN_SIZE_MULTIPLIER=0.5  # Minimum multiplier (slow reversion protection)
MAX_SIZE_MULTIPLIER=2.1  # Maximum multiplier (fast reversion cap)
# Correlation hysteresis thresholds (relaxed thresholds for existing positions/watches)
# Entry requires >= MIN_CORRELATION, but holding/watching allows lower values
CORRELATION_EXIT_THRESHOLD=0.75  # Exit position if correlation drops below this
# Trailing Exit (Trailing SL)
TRAILING_SL_OFFSET=1.0  # Offset from min_z_reached for new SL
TRAILING_SL_ACTIVATION=1.4 # Min Z recovery from entry before trailing SL activates

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=DEBUG
LOG_TO_FILE=false
LOG_DIRECTORY=logs

# =============================================================================
# Database Configuration
# =============================================================================
MONGODB_URI=""
DATABASE_NAME="sigma-core"
PG_DB_URL="postgresql://alpha:alpha_secret@127.0.0.1:5432/alpha_bot"
TIMESCALE_DB_URL=""
REDIS_URL=""

# =====================
# TELEGRAM
# =====================
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""

# =====================
# GRAFANA
# =====================
LOKI_HOST=""
LOKI_USER=
LOKI_TOKEN=""
LOKI_APP_NAME=sigma-core
